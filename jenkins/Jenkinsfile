pipeline {
    agent {
        docker {
            image 'ilyes94/maven-docker-java17'
            args '-v /root/.m2:/root/.m2 -v /var/run/docker.sock:/var/run/docker.sock'
        }
    }

    triggers {
        cron '0 7 * * *'
    }

    environment {
        SONAR_HOST_URL = 'http://10.0.2.15:9000'
        DOCKER_CONFIG = '/tmp/.docker'
    }

    stages {

        stage('Init') {
            steps {
                script {
                    env.APP_NAME = sh(script: "mvn -q -DforceStdout help:evaluate -Dexpression=project.name", returnStdout: true).trim()
                    env.APP_VERSION = sh(script: "mvn -q -DforceStdout help:evaluate -Dexpression=project.version", returnStdout: true).trim()
                }
            }
        }

        stage('Build') {
            steps {
                sh 'mvn -B -DskipTests clean package'
            }
        }

        stage('Test') {
            steps {
                sh 'mvn test'
                sh 'mvn site'   // pour générer les rapports HTML
            }
            post {
                always {
                    // Résultats JUnit
                    junit 'target/surefire-reports/*.xml'

                    // Archive HTML
                    archiveArtifacts artifacts: 'target/site/**', allowEmptyArchive: true

                    // Publication HTML
                    publishHTML(target: [
                        reportDir: 'target/site',
                        reportFiles: 'index.html',
                        reportName: 'Rapport de Tests',
                        keepAll: true,
                        alwaysLinkToLastBuild: true,
                        allowMissing: true
                    ])
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withCredentials([string(credentialsId: 'sonar-token', variable: 'SONAR_TOKEN')]) {
                    sh """
                        mvn sonar:sonar \
                          -Dsonar.projectKey=${env.APP_NAME} \
                          -Dsonar.projectName='${env.APP_NAME}' \
                          -Dsonar.host.url=${env.SONAR_HOST_URL} \
                          -Dsonar.token=${SONAR_TOKEN}
                    """
                }
            }
        }

        stage('Deliver') {
            steps {
                sh 'bash ./jenkins/scripts/deliver.sh'
            }
        }

        stage('Docker Build') {
            steps {
                sh "docker build -t ${env.APP_NAME}:${env.APP_VERSION} ."
            }
        }

        stage('Docker Push') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerHub',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh """
                        echo "${DOCKER_PASS}" | docker login -u "${DOCKER_USER}" --password-stdin
                        docker tag ${env.APP_NAME}:${env.APP_VERSION} ${DOCKER_USER}/${env.APP_NAME}:${env.APP_VERSION}
                        docker push ${DOCKER_USER}/${env.APP_NAME}:${env.APP_VERSION}
                    """
                }
            }
        }

        stage('Deploy') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerHub',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh """
                        docker stop ${env.APP_NAME} || true
                        docker rm ${env.APP_NAME} || true
                        docker run -d \
                            --name ${env.APP_NAME} \
                            --restart unless-stopped \
                            ${DOCKER_USER}/${env.APP_NAME}:${env.APP_VERSION}
                    """
                }
            }
        }
    }

    post {
        success {
            echo "Pipeline terminé avec succès — ${env.APP_NAME}:${env.APP_VERSION}"
        }
        failure {
            echo "Pipeline échoué — vérifiez les logs"
        }
        always {
            sh 'docker logout || true'
        }
    }
}